{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "npm run guard:dev-not-running && node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "guard:dev-not-running": "node -e \"const http=require('http');const msg='Dev server esta a correr na porta 3001. Pare o npm run dev antes de correr npm run build (porque o build apaga .next).';const req=http.request({host:'127.0.0.1',port:3001,path:'/',method:'GET',timeout:250},()=>{console.error(msg);process.exit(1);});req.on('timeout',()=>{req.destroy();process.exit(0);});req.on('error',()=>process.exit(0));req.end();\"",
    "dev": "npm run clean && next dev -H 0.0.0.0 -p 3001",
    "build": "npm run guard:dev-not-running && npm run clean && next build",
    "start": "next start -H 0.0.0.0 -p 3001",
    "lint": "next lint"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.11",
    "@radix-ui/react-avatar": "^1.1.9",
    "@radix-ui/react-context-menu": "^2.2.12",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.12",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.4.0",
    "@shadcn/ui": "^0.0.4",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-table": "^8.21.3",
    "aframe": "^1.7.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "geist": "^1.3.1",
    "heroicons": "^2.2.0",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet-routing-machine": "^3.2.12",
    "lucide-react": "^0.487.0",
    "next": "^15.2.1",
    "next-themes": "^0.4.6",
    "npm": "^11.2.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.1",
    "sweetalert2": "^11.22.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "eslint": "^9",
    "eslint-config-next": "15.1.7",
    "postcss": "^8",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.1"
  }
}